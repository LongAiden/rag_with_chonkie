# ============================================
# SECURITY WARNING - CHANGE ALL DEFAULT VALUES!
# ============================================
# This is a template file. Copy to .env and replace with your actual credentials.
# Usage: cp .env.example .env
#        Then edit .env with your real values

# Local development (without Docker) - set PYTHONPATH so imports resolve
# PYTHONPATH=.

# ============================================
# Database Configuration
# ============================================
# IMPORTANT: Change 'admin' to a strong password in production!
POSTGRES_USER=admin
POSTGRES_PASSWORD=CHANGE_THIS_SECURE_PASSWORD
POSTGRES_DB=rag_db

# ============================================
# API Keys (REQUIRED - Get from respective services)
# ============================================
# Get your Gemini API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Optional: Logfire for monitoring (https://logfire.pydantic.dev/)
LOGFIRE_WRITE_TOKEN=your-logfire-write-token-or-leave-empty
LOGFIRE_READ_TOKEN=your-logfire-read-token-or-leave-empty

# ============================================
# Ollama (Local LLM - runs on host, accessed via host.docker.internal)
# ============================================
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=deepseek-r1:8b
OLLAMA_VLM_MODEL=qwen3.5:4b

# ============================================
# Optional: pgAdmin (Database UI)
# ============================================
PGADMIN_EMAIL=admin@rag.local
PGADMIN_PASSWORD=CHANGE_THIS_PGADMIN_PASSWORD

# ============================================
# Graph & Entity Extraction Configuration
# ============================================

# Chunking Strategy
CHUNKER_TYPE=recursive

# Entity Extraction
ENTITY_CONFIDENCE_THRESHOLD=0.6
ENTITY_EXTRACTION_ENABLED=true
MAX_ENTITIES_PER_CHUNK=50

# Relationship Extraction
RELATIONSHIP_CONFIDENCE_THRESHOLD=0.6
RELATIONSHIP_EXTRACTION_ENABLED=true
MAX_RELATIONSHIPS_PER_CHUNK=100

# Graph Algorithms
DEFAULT_MAX_HOPS=2
PAGERANK_DAMPING_FACTOR=0.85
PAGERANK_MAX_ITERATIONS=100

# LLM Configuration
GEMINI_MODEL=gemini-2.5-flash

# Embedding Model
ENTITY_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
ENTITY_EMBEDDING_DIMENSION=384

# Batch Processing
BATCH_SIZE=10
ENABLE_PARALLEL_EXTRACTION=true

# Performance
ENABLE_ENTITY_CACHING=true
CACHE_TTL_SECONDS=3600

# Database Connection Pool
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10
DB_POOL_TIMEOUT=30.0

# Logging
LOG_LEVEL=INFO
LOG_ENTITY_EXTRACTION=true
LOG_RELATIONSHIP_EXTRACTION=true

# ============================================
# Celery & Frontend Access Control
# ============================================
# Shared password required by the web forms; leave blank to disable
APP_ACCESS_PASSWORD=
# Async extraction queue
USE_CELERY_FOR_EXTRACTION=true
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
# Offload uploads to Celery to keep API responsive
USE_CELERY_FOR_UPLOAD=true

# Langfuse
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_NEXTAUTH_SECRET=changeme-use-a-real-secret-in-prod
LANGFUSE_SALT=changeme-use-a-real-salt-in-prod
LANGFUSE_INIT_ORG_ID=rag-org
LANGFUSE_INIT_PROJECT_ID=rag-project
LANGFUSE_INIT_USER_EMAIL=
LANGFUSE_INIT_USER_PASSWORD=
LANGFUSE_INIT_USER_NAME=
