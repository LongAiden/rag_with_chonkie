# ============================================
# Test Environment Dockerfile
# ============================================

ARG PYTHON_VERSION=3.11

# Use the same base as the main app for consistency
FROM python:${PYTHON_VERSION}-slim

ENV PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1 \
    PYTHONPATH=/app

WORKDIR /app

# Install system dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    g++ \
    libpq-dev \
    curl \
    && rm -rf /var/lib/apt/lists/*

# Copy and install requirements
COPY deployment/requirements.txt ./deployment/
RUN pip install --no-cache-dir -r deployment/requirements.txt

# Install test dependencies
RUN pip install --no-cache-dir \
    pytest>=7.4.0 \
    pytest-asyncio>=0.21.0 \
    pytest-cov>=4.1.0 \
    pytest-mock>=3.11.0 \
    reportlab>=4.0.0

# Download spaCy model at build time
RUN python -m spacy download en_core_web_sm --quiet || echo "spaCy model download skipped"

# Copy application code
COPY api/ ./api/
COPY ingestion/ ./ingestion/
COPY retrieval/ ./retrieval/
COPY models/ ./models/
COPY graph_processing/ ./graph_processing/
COPY worker/ ./worker/
COPY config/ ./config/
COPY repositories/ ./repositories/
COPY observability/ ./observability/
COPY migrations/ ./migrations/

# Note: tests/ directory will be mounted as a volume in docker-compose
# This allows for live test development without rebuilding the image

# Create required directories
RUN mkdir -p /app/data /app/logs /app/uploads /app/htmlcov /app/tests

# Default command runs all tests
CMD ["pytest", "-v", "--cov=.", "--cov-report=html", "--cov-report=term"]
